DB_HOST=db_host
DB_PORT=db_port
DB_NAME=db_name
DB_USER=db_user
DB_PASS=db_password

OMOP_VIEW=distributions_and_concept_view
APP_ENV=development
APP_DEBUG=true
STORE_REFRESH_TTL=60
DEFAULT_THRESHOLD=60

FUZZY_TOKEN_OVERLAP=true
FUZZY_TOKEN_MIN_SCORE=85
RESOLVER_MAX_MATCHES=5

# Very experimental acronym extraction feature
# Acronyms are calculated eagerly on concept load (per resolver instance).
# The acronym index is then cached in memory inside QueryParser and reused
# until the resolver's concept list changes.
ACRONYM_ENABLED=true

# Applies a logarithmic boost to concepts that are with multiple collections,
# to de-saturate larger datasets monopolising omop concepts purely on size.
#
# Can be set to 0 to disable additional weighting.
COLLECTION_BOOST_WEIGHT=1.5
